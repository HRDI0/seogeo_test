# Render (Backend)
APP_ENV=production
TOKEN_STORE_MODE=encrypted

# 32-byte urlsafe-base64 keys. Generate via:
# python -c "from src.seogeo_reporter.security import generate_key_b64; print(generate_key_b64())"
