GEMINI_API_KEY=
PERPLEXITY_API_KEY=

# R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Runtime controls
RUN_MODE=mock
PROMPT_MODE=mock
REPORT_MONTH=
CLIENT_NAME=Demo Client
SITE_URL=https://example.com
REPORT_OUTPUT_PATH=
GA4_PROPERTY_ID=
